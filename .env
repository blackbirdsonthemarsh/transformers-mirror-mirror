STYLE_SETTINGS_BODY_CLASSES=mod-linux is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon css-settings-manager hider-status hider-instructions hider-vault is-maximized theme-light is-focused anp-td-none ctp-latte ctp-frappe ctp-accent-light-maroon ctp-accent-rosewater anuppuccin-accent-toggle anp-no-highlight anp-callout-sleek anp-callout-color-toggle anp-latex-inline-text anp-latex-block-text anp-toggle-metadata anp-hide-status-bar anp-tooltip-toggle anp-hide-external-link-icon anp-header-color-toggle anp-header-divider-color-toggle anp-h1-sapphire anp-h1-divider anp-h2-peach anp-h3-green anp-h4-teal anp-h5-lavender anp-h6-mauve anp-decoration-toggle anp-bold-lavender anp-italic-green anp-highlight-yellow anp-default-rainbow anp-full-rainbow-text-color-toggle-dark anp-simple-rainbow-title-toggle anp-floating-status-bar anp-mini-tab-toggle anp-card-layout anp-hide-borders anp-card-layout-filebrowser
