SITE_NAME_HEADER=Mirror Mirror
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://transformers-mirror-mirror.vercel.app/
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=dd, MMM, yyyy
SHOW_UPDATED_TIMESTAMP=false
NOTE_ICON_DEFAULT=default
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-linux is-frameless is-hidden-frameless obsidian-app styled-scrollbars theme-light show-inline-title is-floating-nav auto-full-screen show-ribbon is-maximized css-settings-manager hider-status hider-instructions hider-vault is-focused a-catpuccin-mocha smoothIndent
USE_FULL_RESOLUTION_IMAGES=false
THEME=https://raw.githubusercontent.com/AmadeusWM/Obsidian-Apatheia/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=false
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=false